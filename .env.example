# =============================================
# She Can Foundation - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit your real .env file to GitHub!

# ── Server ──────────────────────────────────
PORT=3000

# ── Neon PostgreSQL ──────────────────────────
# Get this from: https://console.neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://your_user:your_password@your-neon-host.neon.tech/neondb?sslmode=require

# ── Frontend URL (for CORS) ──────────────────
# Local dev: http://localhost:3000
# Production: https://your-vercel-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── Admin Secret (for /api/admin/submissions) ─
ADMIN_SECRET=change_this_to_a_strong_secret_key
